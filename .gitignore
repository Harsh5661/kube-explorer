```gitignore
# Dependencies
node_modules/

# Build output
dist/
build/

# Electron/Vite packaged output
release/
win-unpacked/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment files
.env
.env.local
.env.*

# OS files
.DS_Store
Thumbs.db

# IDE/editor
.vscode/
.idea/

# Temporary files
tmp/
temp/

# Cache
.cache/
.vite/

# Package manager
.pnpm-store/
```
